# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:monospace 11

# Gruvbox Colors
set $bg #282828
set $bg1 #3c3836
set $bg2 #504945
set $fg #ebdbb2
set $fg4 #a89984
set $red #cc241d
set $green #98971a
set $yellow #d79921
set $blue #458588
set $purple #b16286
set $aqua #689d68
set $gray #a89984
set $darkgray #1d2021
set $orange #d65d0e
set $bgalpha #282828cc
set $darkgrayalpha #1d2021cc
set $purplealpha #b16286cc

# Border
#default_border none
#default_floating_border none
default_border pixel 2
default_floating_border normal 2
#client.<class>         <border>        <background>    <text>  <indicator>     <child_border>
client.focused          $bg2            $bg2            $fg     $bgalpha        $aqua
client.focused_inactive $bg2            $bg2            $fg4    $bgalpha        
client.unfocused        $darkgray       $darkgray       $fg4    $darkgrayalpha
client.urgent           $purple         $purple         $fg     $purplealpha
title_align center

# Gaps
gaps inner 2
gaps outer 2
# Only enable gaps on a workspace when there is at least one container
# smart_gaps on

output * bg $HOME/Pictures/.wallpaper fill

# cursor
seat seat0 xcursor_theme phinger-cursors-light 24